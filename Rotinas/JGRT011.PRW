/*/{Protheus.doc} JGRT11_B

	Rotina para gerar a nota de entrada no destino, quando a nota de saэda jс tiver sido lanчada e excluэda anteriormente.

@type function
@version 1.0
@author  Jesus Ramos
@since   22/05/2026
@return  Logical, .T. para sucesso na geraчуo da nota de entrada, .F. para falha na geraчуo da nota de entrada.
/*/
User Function JGRT11_B()

	Local _aArea := FWGetArea()
	Local cIdMov := ""
	Local lRet   := .T.

	cIdMov := "["+SC5->C5_FILIAL +"-"+ SC5->C5_NUM +"]"
	U_FLOGJG(cIdMov+" "+ProcName(1) +">"+ ProcName(0) + " SM0:"+SM0->M0_CODFIL+" cFilAnt: "+cFilAnt )

	If Alltrim(SC5->C5_NOTA) = "XXXXXX"
		FWAlertWarning(OemToAnsi("O Pedido estс cancelado/residuado!"), OemToAnsi("Atenчуo"))

	ElseIf !(SC5->C5_XMOVTRF == JGTrPVExD)
		FWAlertWarning(OemToAnsi("Esta opчуo destina-se, unicamente, a um novo registro da entrada da nota fiscal de transferъncia na filial de destino, "+CRLF+;
									"quando esta foi lanчada anteriormente e excluэda."+CRLF+CRLF+;
									"Esta operaчуo de transferъncia encontra-se com o status <b>"+U_fDsStTrf("P",SC5->C5_XMOVTRF)+"</b>"+;
									", portanto, nуo pode ser processada por esta opчуo."), OemToAnsi("Atenчуo"))

	ElseIf FWAlertYesNo("Confirma a re-inclusуo da Nota de Entrada na filial de Destino?"+CRLF+CRLF+"Filial: "+SC5->C5_FILIAL+" Doc./Sщrie: "+SC5->C5_NOTA+"/"+SC5->C5_SERIE, "Atenчуo")

		U_FLOGJG(cIdMov+" Antes U_JGRT11_B - Gera nota de entrada na filial de destino"+" Time:"+TIME())
		FWMsgRun(, { |oSay| lRet := U_JGRT13A(@oSay,SC5->C5_FILIAL,SC5->C5_NOTA,SC5->C5_SERIE) }, "Processando - Nota de Entrada no Destino", "Aguarde, processando a rotina" )
		U_FLOGJG(cIdMov+" Nota de entrada gerada na filial de destino? "+IIf(lRet,"Sim","Nуo")+" Time:"+TIME())

		If lRet
			U_JGRT11_E(SC5->(Recno()), JGTrPVOK, JGTrOrOK)//Grava Status no Pedido e no Orчamento
		EndIf
		U_FLOGJG(cIdMov+" Depois U_JGRT11_B - Gera nota de entrada na filial de destino"+" Time:"+TIME())

	EndIf

	FWRestArea(_aArea)

Return(lRet)

/*/{Protheus.doc} JGRT11_C

	Rotina para liberar a transferъncia de estoque sem realizar a separaчуo dos itens.

@type function
@version  
@author Samsung
@since 22/05/2026
@return Logical, .T. para sucesso no cancelamento, .F. para falhoa no cancelamento.
/*/
User Function JGRT11_C()

	Local _aArea       := FWGetArea()
	Local cIdMov       := ""
	Local lRet         := .F.
	Local lLiberar     := .F.
	Local nItensPed    := 0
	Local nSemOrdSep   := 0
	Local nOrdNaoFin   := 0
	Local nLoteComErro := 0
	Local nRecnoPed	   := SC5->(Recno())

	cIdMov := "["+SC5->C5_FILIAL +"-"+ SC5->C5_NUM +"]"
	U_FLOGJG(cIdMov+" "+ProcName(1) +">"+ ProcName(0) + " SM0:"+SM0->M0_CODFIL+" cFilAnt: "+cFilAnt )

	If Alltrim(SC5->C5_NOTA) = "XXXXXX"
		FWAlertWarning(OemToAnsi("O Pedido estс cancelado/residuado!"), OemToAnsi("Atenчуo"))
	ElseIf !Empty(SC5->C5_NOTA)
		FWAlertWarning(OemToAnsi("O Pedido jс foi faturado!"), OemToAnsi("Atenчуo"))
	ElseIf !(SC5->C5_XMOVTRF == JGTrPVPSp)
		FWAlertWarning(OemToAnsi("Esta opчуo destina-se, unicamente, a liberar um pedido de transferъncia que esteja com status <b>Pendente de Separaчуo</b>"+;
									" e que nуo possua ordem(s) de separaчуo gerada(s) ou, se existirem, jс estejam finalizadas."+CRLF+CRLF+;
									"Esta operaчуo de transferъncia encontra-se com o status <b>"+U_fDsStTrf("P",SC5->C5_XMOVTRF)+"</b>"+;
									", portanto, nуo pode ser processada por esta opчуo."), OemToAnsi("Atenчуo"))

	Else

	    nItensPed    := fItensPed(SC5->C5_FILIAL, SC5->C5_NUM)
	    nSemOrdSep   := fSemOrdSep(SC5->C5_FILIAL, SC5->C5_NUM)
	    nOrdNaoFin   := fOrdNaoFin(SC5->C5_FILIAL, SC5->C5_NUM)
		nLoteComErro := fLoteComErro(SC5->C5_FILIAL, SC5->C5_NUM)

	    If nItensPed = 0
			FWAlertWarning(OemToAnsi("Nуo foram localizados itens para o pedido."+CRLF+;
										"Verifique se o pedido ainda existe lanчado no sistema."), OemToAnsi("Atenчуo"))
	    ElseIf nLoteComErro > 0
			FWAlertWarning(OemToAnsi("Algum(ns) item(ns) que exige(m) lote/serial nуo teve(tiveram) o apontamento do lote/serial, "+;
									"ou o lote/serial apontado nуo existe ou estс inconsistente?"+CRLF+CRLF+;
									"Provavelmente, a melhor soluчуo serс realizar a separaчуo para preencher os lotes/seriais faltantes."+CRLF+CRLF+;
									"Revise os lanчamentos para poder prosseguir."), OemToAnsi("Atenчуo"))
	    ElseIf nOrdNaoFin > 0
			FWAlertWarning(OemToAnsi("Existem ordens de separaчуo nуo finalizadas."+CRLF+CRLF+;
										"Finalize a separaчуo para as ordens ainda em aberto/andamento "+;
										"ou estorne as ordens de separaчуo para conseguir liberar a transferъncia sem separaчуo."), OemToAnsi("Atenчуo"))

		Else

			If nSemOrdSep > 0 .And. nSemOrdSep <> nItensPed
				lLiberar := FWAlertYesNo(OemToAnsi("Nуo foram geradas ordens de separaчуo para todos os itens do pedido."+CRLF+;
													"Porщm, as ordens de separaчуo geradas foram todas finalizadas."+CRLF+CRLF+;
													"Deseja liberar a transferъncia sem separar os demais produtos?"), OemToAnsi("Libera?"))
			Else
				lLiberar := FWAlertYesNo("Confirma a liberaчуo do pedido sem realizar a separaчуo?", "Liberaчуo")
			EndIf

			If lLiberar

				SC5->(DbGoTo(nRecnoPed))

				If !SC5->(Deleted())

					If SoftLock("SC5") //Evitar de 2 usuсrios tentar executar no mesmo tempo

						If SC5->C5_XMOVTRF == JGTrPVPSp

							U_FLOGJG(cIdMov+" Antes U_JGRT11_C - Libera pedido sem Separaчуo"+" Time:"+TIME())
							U_JGRT11_E(SC5->(Recno()), JGTrPVPFt, JGTrOrPPF)//Grava Status no Pedido e no Orчamento
							U_JGRT11_D("P", SC5->(Recno()), "Separaчуo liberada pelo usuсrio: "+__cUserId+"-"+cUserName+" em "+DToC(Date())+" рs "+Time())//Grava Status no Pedido e no Orчamento

							If SC5->C5_XMOVTRF == JGTrPVPFt
								lRet := .T.
								FWAlertInfo(OemToAnsi("Liberaчуo efetuada com sucesso."), OemToAnsi("Sucesso"))
							Else
								FWAlertInfo(OemToAnsi("A liberaчуo nуo foi efetuada como esperado."+CRLF+CRLF+;
														"Reavalie a situaчуo do pedido."), OemToAnsi("Atenчуo"))
							EndIf
							U_FLOGJG(cIdMov+" Transferъncia liberada sem separaчуo? "+IIf(lRet,"Sim","Nуo")+" Time:"+TIME())
							U_FLOGJG(cIdMov+" Depois U_JGRT11_C - Libera pedido sem Separaчуo"+" Time:"+TIME())

						Else
							FWAlertInfo(OemToAnsi("O pedido mudou de situaчуo durante a confirmaчуo da rotina."+CRLF+CRLF+;
													"Reavalie a necessidade de execuчуo."), OemToAnsi("Status"))
						EndIf

						If IsLocked("SC5", SC5->(Recno()))
							SC5->(MsrUnlock()) //Libera o SoftLock
						EndIf

					Else
						FWAlertInfo(OemToAnsi("Nуo foi possэvel reservar o pedido para efetuarmos a liberaчуo da separaчуo do pedido."+CRLF+;
												"Algum outro processo estс bloqueando este pedido."+CRLF+CRLF+;
												"Saia e tente novamente."), OemToAnsi("Bloqueado"))

					EndIf

				Else
					FWAlertError(OemToAnsi("O pedido foi excluэdo enquanto preparсvamos para iniciar."+CRLF+CRLF+;
											"O cancelamento/resэduo nуo poderс prosseguir. Saia e verifique a situaчуo real do pedido."), OemToAnsi("Atenчуo"))

				EndIf

			Else
				FWAlertInfo(OemToAnsi("A liberaчуo da separaчуo do pedido foi abortada pelo usuсrio."), OemToAnsi("Atenчуo"))

			EndIf
		EndIf

	EndIf

	FWRestArea(_aArea)

Return(lRet)


/*/{Protheus.doc} JGRT11_D

	Grava o log de ocorrъncias no pedido de transferъncia e orчamento, quando necessсrio.

@type function
@version  1.0
@author Jesus Ramos
@since 06/05/2026
@param cIdentOrig, numeric, Tipo que identifica se o conte·do de nRecno щ referente ao orчamento ou pedido, onde: O - Orчamento, P - Pedido.
@param nRecno, numeric, N·mero do registro (recno) do orчamento/pedido.
@param cTextoLog, character, Texto do log a ser gravado no campo de observaчєes do orчamento/pedido.
@return Logical, Indica se a gravaчуo do log foi realizada com sucesso (.T.) ou nуo (.F.).
/*/
User Function JGRT11_D(cIdentOrig, nRecno, cTextoLog)

	Local lRet       := .F.
	Local _cAliasAnt := Alias()
	Local _aArea     := FWGetArea()
	Local _aAreaSC5  := SC5->(FWGetArea())
	Local _aAreaSL1  := SL1->(FWGetArea())
	Local cLinhaLog  := DToC(Date())+" - "+Time()+" - Usuсrio: "+__cUserId+"-"+cUserName+" - "+ProcName(1)+">"+ProcName(0)+CRLF+cTextoLog+CRLF

	U_FLOGJG(ProcName(1) +">"+ ProcName(0) + " SM0:"+SM0->M0_CODFIL+" cFilAnt: "+cFilAnt )

	Default cIdentOrig := ""
	Default nRecno     := 0
	Default cTextoLog  := ""

	//Begin Transaction

	If !Empty(nRecno) .And. !Empty(cTextoLog)
		If cIdentOrig == "O"
			SL1->(DbGoTo(nRecno))
			If SL1->(Recno()) = nRecno
				If RecLock("SL1", .F.)
					SL1->L1_XLOGTRF += cLinhaLog
					SL1->(MsUnlock())
					lRet := .T.
				EndIf
			EndIf
		ElseIf cIdentOrig == "P"
			SC5->(DbGoTo(nRecno))
			If SC5->(Recno()) = nRecno
				If RecLock("SC5", .F.)
					SC5->C5_XLOGTRF += cLinhaLog
					SC5->(MsUnlock())
					lRet := .T.
				EndIf
			EndIf
			If !Empty(SC5->C5_XFILTRF) .And. !Empty(SC5->C5_XORCTRF)
				If SL1->(DbSeek(SC5->C5_XFILTRF+SC5->C5_XORCTRF)) .And. SL1->(L1_FILIAL+L1_NUM) == SC5->(C5_XFILTRF+C5_XORCTRF) .And. Empty(SL1->L1_DOC)
					If RecLock("SL1", .F.)
						SL1->L1_XLOGTRF += cLinhaLog
						SL1->(MsUnlock())
					EndIf
				EndIf
			EndIf
		EndIf
	EndIf

	//End Transaction

	FWRestArea(_aAreaSL1)
	FWRestArea(_aAreaSC5)
	FWRestArea(_aArea)
	DbSelectArea(_cAliasAnt)

Return(lRet)


/*
▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒╠══════════╪════════════╩═══════╧════════════════════╩══════╧═════════════╣▒▒
▒▒║Descricao │ Grava Status no Pedido de venda								║▒▒
▒▒║          │                                  							║▒▒
▒▒╠══════════╪══════════════════════════════════════════════════════════════╣▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
User Function JGRT11_E(nSC5RECNO, cPedStatus, cOrcStatus)

	Local lRet       := .F.
	Local _cAliasAnt := Alias()
	Local _aArea     := FWGetArea()
	Local _aAreaSC5  := SC5->(FWGetArea())
	Local _aAreaSL1  := SL1->(FWGetArea())

	U_FLOGJG(ProcName(1) +">"+ ProcName(0) + " SM0:"+SM0->M0_CODFIL+" cFilAnt: "+cFilAnt )

	Default nSC5RECNO := 0
	Default cPedStatus := ""
	Default cOrcStatus := ""

	//Begin Transaction

	If 	nSC5RECNO > 0 .And. !Empty(cPedStatus)
		SC5->(DbGoTo(nSC5RECNO))
		If SC5->(RECNO()) = nSC5RECNO
			If RecLock("SC5", .F.)
				SC5->C5_XMOVTRF := cPedStatus
				SC5->(MsUnlock())
				lRet := .T.
			EndIf
		EndIf
		If !Empty(cOrcStatus) .And. !Empty(SC5->C5_XFILTRF) .And. !Empty(SC5->C5_XORCTRF)
			If SL1->(DbSeek(SC5->C5_XFILTRF+SC5->C5_XORCTRF)) .And. SL1->(L1_FILIAL+L1_NUM) == SC5->(C5_XFILTRF+C5_XORCTRF) .And. Empty(SL1->L1_DOC)
				If RecLock("SL1", .F.)
					If SL1->L1_XMOVTRF == JGTrOrCan .And. cOrcStatus == JGTrOrEAb
						SL1->L1_XPEDTRF := ""
					EndIf
					SL1->L1_XMOVTRF := cOrcStatus
					SL1->(MsUnlock())
				EndIf
			EndIf
		EndIf
	EndIf

	//End Transaction

	FWRestArea(_aAreaSL1)
	FWRestArea(_aAreaSC5)
	FWRestArea(_aArea)
	DbSelectArea(_cAliasAnt)

Return(lRet)

/*
▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒╠══════════╪════════════╩═══════╧════════════════════╩══════╧═════════════╣▒▒
▒▒║Descricao │ Verifica o cFilAnt x SM0										   ║▒▒
▒▒║          │                                  								   ║▒▒
▒▒╠══════════╪══════════════════════════════════════════════════════════════╣▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
User Function JGRT11_F(cNewFilial)
	Local cFilOld := cFilAnt

	Default cNewFilial  := ""

	If cNewFilial <> cFilAnt
		cFilAnt := IIf(Empty(cNewFilial), cFilAnt, cNewFilial)
	EndIf
	FWSM0Util():setSM0PositionBycFilant()
	U_FLOGJG(ProcName(1) +">"+ ProcName(0) + " - SM0 POSICIONADA CONFORME CFILANT >>> SM0:"+cFilAnt +" -->SM0_OLD: "+cFilOld)

Return()

/*
▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▒▒╠══════════╪════════════╩═══════╧════════════════════╩══════╧═════════════╣▒▒
▒▒║Descricao │ Gera Danfe														   ║▒▒
▒▒║          │                                  								   ║▒▒
▒▒╠══════════╪══════════════════════════════════════════════════════════════╣▒▒
▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀
*/
User Function JGRT11_J()
	Local lRet       := .T.
	Local nIntervalo := 0

	//MsgInfo("Executa Job Manualmente")

	FWMsgRun(, {|oSay| U_JGRT012(cEmpAnt, cFilAnt, nIntervalo) }, "Processando o Job de Transferъncias...", "Aguarde, processando a rotina" )

	// Processa({|| U_JGRT012(cEmpAnt, cFilAnt, nIntervalo) }, "Processando o Job de Transferъncias...")

Return(lRet)


/*┌────────────────────────────────────────────────────────────────────────────┐
│                Verifica o documento no destino			                   │
└────────────────────────────────────────────────────────────────────────────┘*/
Static Function xNfDest(_cFil, _cNota, __cSerieNf, _cCNPJ)
	
	Local lRet      := .F.
	Local cQuery    := ""
	Local cCodFor   := " "
	Local cLojaFor  := " "
	Local cAliasMov
	
	SA2->(dbsetOrder(3))
	If SA2->(dbSeek(xFilial("SA2")+_cCNPJ))
		cCodFor  := SA2->A2_COD
		cLojaFor := SA2->A2_LOJA
	EndIf
	
	cQuery := " SELECT DISTINCT " + CRLF
	cQuery := "     1 " + CRLF
	cQuery += " FROM " + CRLF
	cQuery += "     " + CRLFRetSqlName("SF1") + " SF1 "
	cQuery += " WHERE " + CRLF
	cQuery += "     F1_FILIAL      = " + ValToSql(_cFil) + " " + CRLF
	cQuery += "     AND F1_DOC     = " + ValToSql(_cNota) + " " + CRLF
	cQuery += "     AND F1_SERIE   = " + ValToSql(__cSerieNf) + " " + CRLF
	cQuery += "     AND F1_FORNECE = " + ValToSql(cCodFor) + " " + CRLF
	cQuery += "     AND F1_LOJA    = " + ValToSql(cLojaFor) + " " + CRLF
	cQuery += "     AND D_E_L_E_T_ <> '*' " + CRLF

	cAliasMov := MPSysOpenQuery( cQuery )
	
	If (cAliasMov)->(Eof())
		lRet := .F.
	Else
		lRet := .T.
	EndIf
	
	(cAliasMov)->( dbCloseArea() )
	
Return(lRet)

/*/{Protheus.doc} fRvStTrPV
description
	Reverte o status da transferъncia do Pedido de Venda recebido para o status imediatamente anterior.
@type user function
@version  
@author Jesus Ramos
@since 12/03/2026
@param cStTrfPV, character, param_description
@return variant, return_description
/*/
User Function fRvStTrPV(cStTrfPV)
	Local cNewStPV := ""

	Do Case
        Case cStTrfPV == JGTrPVOK 
            cNewStPV := JGTrPVNPE
        Case cStTrfPV == JGTrPVNPE
            cStTrfPV := JGTrPVNPA
        Case cStTrfPV == JGTrPVNPA
            cNewStPV := JGTrPVPFt
        Case cStTrfPV == JGTrPVPFt
            cNewStPV := JGTrPVPSp
        Case cStTrfPV == JGTrPVExD
            cNewStPV := JGTrOrOK
        Otherwise
            cNewStPV := " "
    EndCase

Return cNewStPV

/*/{Protheus.doc} fRvStTrOr
description
	Reverte o status da transferъncia do Orчamento recebido para o status imediatamente anterior.
@type user function
@version  
@author Jesus Ramos
@since 12/03/2026
@param cStTrfPV, character, param_description
@return variant, return_description
/*/
User Function fRvStTrOr(cStTrfOrc)
	Local cNewStOrc := ""

	Do Case
        Case cStTrfOrc == JGTrOrIni 
            cNewStOrc := JGTrOrEAb
        Case cStTrfOrc == JGTrOrPPS
            cNewStOrc := JGTrOrIni
        Case cStTrfOrc == JGTrOrPPF
            cNewStOrc := JGTrOrPPS
        Case cStTrfOrc == JGTrOrNPA
            cNewStOrc := JGTrOrPPF
        Case cStTrfOrc == JGTrOrNPE
            cNewStOrc := JGTrOrNPA
        Case cStTrfOrc == JGTrOrOK
            cNewStOrc := JGTrOrNPE
        Otherwise
            cNewStOrc := " "
    EndCase

Return cNewStOrc


/*/{Protheus.doc} JGRT11_G

	Rotina de acionamento e controle da operaчуo de resэduo (cancelamento) do pedido de transferъncia.

@type    function
@version 1.0
@author  Jesus Ramos
@since   22/05/2026
@return  Nil
/*/
User Function JGRT11_G(p_Ms520Del)
	Local cRet       As String
	Local cIdMov     As String
	Local nRecnoPed  As Numeric
	Local nItensPed  As Numeric
	Local nSemOrdSep As Numeric
	Local nOrdNaoFin As Numeric
	Local cMsgRes    As String

	Default p_Ms520Del := .F.

	nRecnoPed  := SC5->(Recno())
	cRet       := ""
	nItensPed  := 0
	nSemOrdSep := 0
	nOrdNaoFin := 0
	cMsgRes    := ""

	cIdMov := "["+SC5->C5_FILIAL +"-"+ SC5->C5_XFILTRF +"-"+ SC5->C5_NUM +"]"
	U_FLOGJG(cIdMov+" -Antes U_JGRT11G1 - Cancela Transferъncia (Residua)"+" Time:"+TIME())

	// Valida os campos necessсrios para autorizar o resэduo do pedido de transferъncia
	If !(SC5->C5_XMOVTRF $ JGTrPVPSp+"/"+JGTrPVPFt+"/"+JGTrPVExO+"/"+JGTrPVOS) // O pedido precisa estar com status Pendente de Separaчуo ou Pendente de Faturamento.

		cMsgRes := "O pedido precisa estar com os seguintes status:"+CRLF+CRLF+;
					"  -> Pendente de Separaчуo"+CRLF+;
					"  -> Pendente de Faturamento"
		If IsBlind() .Or. p_Ms520Del
			U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
		Else
			FWAlertWarning(OemToAnsi(cMsgRes), OemToAnsi("Cancelamento da Transferъncia"))
		EndIf

	ElseIf "X" $ SC5->C5_NOTA // Pedido jс residuado nуo entra na Rotina

		cMsgRes := "O pedido jс se encontra residuado."
		If IsBlind() .Or. p_Ms520Del
			U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
		Else
			FWAlertWarning(OemToAnsi(cMsgRes), OemToAnsi("Cancelamento da Transferъncia"))
		EndIf

	ElseIf !Empty(SC5->C5_NOTA) // Pedido jс faturado nуo entra na Rotina

		cMsgRes := "O pedido jс se encontra faturado, nуo sendo possэvel efetuar seu cancelamento/resэduo."
		If IsBlind() .Or. p_Ms520Del
			U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
		Else
			FWAlertWarning(OemToAnsi(cMsgRes), OemToAnsi("Cancelamento da Transferъncia"))
		EndIf

	Else

	    nItensPed    := fItensPed(SC5->C5_FILIAL, SC5->C5_NUM)
	    nSemOrdSep   := fSemOrdSep(SC5->C5_FILIAL, SC5->C5_NUM)
	    nOrdNaoFin   := fOrdNaoFin(SC5->C5_FILIAL, SC5->C5_NUM)

	    If nItensPed = 0

			cMsgRes := "Nуo foram localizados itens para o pedido."
			If IsBlind() .Or. p_Ms520Del
				U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
			Else
				FWAlertWarning(OemToAnsi(cMsgRes), OemToAnsi("Atenчуo"))
			EndIf

	    ElseIf nSemOrdSep < nItensPed .Or. nOrdNaoFin > 0

			cMsgRes := "Existem ordens de separaчуo vinculadas a este pedido."+CRLF+CRLF+;
						"Para que seja possэvel o cancelamento deste pedido, faz-se necessсrio cancelar/excluir/estornar "+;
						"as ordens de separaчуo."

			If p_Ms520Del .Or. SoftLock("SC5") //Evitar de 2 usuсrios tentar executar no mesmo tempo
				If SC5->C5_XMOVTRF $ JGTrPVPSp+"/"+JGTrPVPFt+"/"+JGTrPVExO+"/"+JGTrPVOS
					U_JGRT11_E(SC5->(Recno()), JGTrPVOS, JGTrOrOS)//Grava Status no Pedido
					U_JGRT11_D("P", SC5->(Recno()), DToC(Date()) + " - Time:"+TIME() + " - "+cMsgRes)//Grava Status no Pedido e no Orчamento
				EndIf
				If !p_Ms520Del .And. IsLocked("SC5", SC5->(Recno()))
					SC5->(MsrUnlock()) //Libera o SoftLock
				EndIf
			EndIf

			If IsBlind() .Or. p_Ms520Del
				U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
			Else
				FWAlertWarning(OemToAnsi(cMsgRes), OemToAnsi("Atenчуo"))
			EndIf

		Else

			If IsBlind() .Or. FWAlertYesNo(OemToAnsi("Confirma o cancelamento desta transferъncia?"), OemToAnsi("Cancelamento da Transferъncia"))

				SC5->(DbGoTo(nRecnoPed))

				If !SC5->(Deleted())

					// cIdMov := ""

					If p_Ms520Del .Or. SoftLock("SC5") //Evitar de 2 usuсrios tentar executar no mesmo tempo

						If SC5->C5_XMOVTRF $ JGTrPVPSp+"/"+JGTrPVPFt+"/"+JGTrPVExO

							// cIdMov := "["+SC5->C5_FILIAL +"-"+ SC5->C5_XFILTRF +"-"+ SC5->C5_NUM +"]"
							U_FLOGJG(cIdMov+" Antes U_JGRT11G1 - Cancela Transferъncia (Residua)"+" Time:"+TIME())

							cRet := ""
							If IsBlind() .Or. p_Ms520Del
								cRet := U_JGRT11G1()
							Else
								FWMsgRun(, {|oSay| cRet := U_JGRT11G1() }, "Processando o cancelamento da transferъncia selecionada...", "Aguarde, processando a rotina" )
							EndIf

							U_FLOGJG(cIdMov+" Retorno: "+IIf(Empty(cRet),"Sucesso",cRet)+" Time:"+TIME())
							U_FLOGJG(cIdMov+" Depois U_JGRT11G1 - Cancela Transferъncia (Residua)"+" Time:"+TIME())

							If Empty(cRet)
								cMsgRes := "O cancelamento da transferъncia foi processado com sucesso."
								If IsBlind() .Or. p_Ms520Del
									U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
								Else
									FWAlertSuccess(OemToAnsi(cMsgRes), OemToAnsi("Transferъncia cancelada"))
								EndIf
							Else
								If IsBlind() .Or. p_Ms520Del
									U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
								Else
									FWAlertError(OemToAnsi(cRet), OemToAnsi("Falha no cancelamento"))
								EndIf
							EndIf

						Else

							cMsgRes := "O pedido mudou de situaчуo durante a confirmaчуo da rotina."+CRLF+CRLF+;
										"Reavalie a necessidade de execuчуo."
							If IsBlind() .Or. p_Ms520Del
								U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
							Else
								FWAlertInfo(OemToAnsi(cMsgRes), OemToAnsi("Status"))
							EndIf

						EndIf

						If !p_Ms520Del .And. IsLocked("SC5", SC5->(Recno()))
							SC5->(MsrUnlock()) //Libera o SoftLock
						EndIf

					Else

						cMsgRes := "Nуo foi possэvel reservar o pedido para efetuarmos o cancelamento/resэduo."+CRLF+;
									"Algum outro processo estс bloqueando este pedido."+CRLF+CRLF+;
									"Saia e tente novamente."
						If IsBlind() .Or. p_Ms520Del
							U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
						Else
							FWAlertInfo(OemToAnsi(cMsgRes), OemToAnsi("Bloqueado"))
						EndIf

					EndIf

				Else

					cMsgRes := "O pedido foi excluэdo enquanto preparсvamos para iniciar."+CRLF+CRLF+;
								"O cancelamento/resэduo nуo poderс prosseguir. Saia e verifique a situaчуo real do pedido."
					If IsBlind() .Or. p_Ms520Del
						U_FLOGJG(cIdMov + " - Time:"+TIME() + " - "+cMsgRes)
					Else
						FWAlertError(OemToAnsi(cMsgRes), OemToAnsi("Atenчуo"))
					EndIf

				EndIf

			Else

				FWAlertInfo(OemToAnsi("O cancelamento da transferъncia foi abortado pelo usuсrio."), OemToAnsi("Cancelamento da Transferъncia"))

			EndIf
		EndIf
	EndIf

Return

/*/{Protheus.doc} JGRT11G1

	Rotina para resэduo (cancelamento) do pedido de transferъncia, cancelando o processo de transferъncia em andamento.
	Somente aceito para pedidos de transferъncia com status:
		- JGTrPVPSp - PV Pendente Separar;
		- JGTrPVPFt - PV Pendente Faturar.
	Caso seja transferъncia para o Varejo (Venda Assistida), atualiza, tambщm, o status do orчamento, retornando-o para:
		- JGTrOrEAb - Orчamento em Aberto.

@type    function
@version 1.0
@author  Jesus Ramos
@since   21/05/2026
@return  Nil
/*/
User Function JGRT11G1()

    Local aAreaSC5 As Array
    Local aAreaSC6 As Array
    Local aAreaSC9 As Array
    Local lSC6OK   As Logical
	Local cStatus  As String
	Local bBlock

    Private __cErr 	 //ErrorBlock
    Private __cStack //ErrorBlock

    aAreaSC5 := SC5->(FWGetArea())
    aAreaSC6 := SC6->(FWGetArea())
    aAreaSC9 := SC9->(FWGetArea())
    lSC6OK   := .F.
	cStatus  := ""
	__cErr   := ""
	__cStack := ""

    bBlock := ErrorBlock() 

    BEGIN SEQUENCE

		ErrorBlock( { |oError| __cErr:=oError:Description , __cStack:=oError:ErrorStack , Break(oError) } )

		Begin Transaction

			U_JGRT11_E(SC5->(Recno()), JGTrPVCan, JGTrOrCan)//Grava Status no Pedido

			SC6->(dbsetorder(1))
			If SC6->( dbseek( SC5->C5_FILIAL+SC5->C5_NUM ))

				While !SC6->(Eof()) .and. SC6->(C6_FILIAL+C6_NUM) == SC5->(C5_FILIAL+C5_NUM)

					RecLock("SC6", .F.)
						SC6->C6_QTDEMP := 0
						SC6->C6_QTDLIB := 0
					SC6->(MsUnLock())

					lSC6OK := .T.

					SC6->(dbskip())
				EndDo

			EndIf

			If lSC6OK

				SC9->(dbsetorder(1))
				If SC9->(dbseek(SC5->C5_FILIAL+SC5->C5_NUM))

					While !Eof() .and. SC9->C9_FILIAL+SC9->C9_PEDIDO == SC5->C5_FILIAL+SC5->C5_NUM
						SC9->(a460estorna())
						SC9->(dbskip())
					EndDo

				EndIf

				If RecLock("SC5", .F.)
					SC5->C5_NOTA  := "XXXXXX"
					SC5->C5_SERIE := "XXX"
					SC5->(MsUnlock()) 
				EndIf   

				SC6->(dbsetorder(1))
				If SC6->(dbseek( SC5->C5_FILIAL+SC5->C5_NUM ))

					While !SC6->(Eof()) .and. SC6->(C6_FILIAL+C6_NUM) == SC5->(C5_FILIAL+C5_NUM)

						If RecLock("SC6",.f.)
							SC6->C6_NOTA   := "XXXXXX"
							SC6->C6_SERIE  := "XXX"
							SC6->C6_QTDENT := SC6->C6_QTDVEN
							SC6->C6_BLQ    := "R"
							SC6->(MsUnLock())
						EndIf

						SC6->(dbskip())

					EndDo

				EndIf

			EndIf

			U_JGRT11_E(SC5->(Recno()), JGTrPVCan, JGTrOrEAb)//Grava Status no Pedido

		End Transaction

    RECOVER
        //RECOVER - Define um ponto de recuperaчуo, dentro do bloco de sequъncia, para o qual o 
        //fluxo de execuчуo serс desviado apґs a execuчуo de um comando BREAK.

		If InTransact()
			DisarmTransaction()
		EndIf

        cStatus := __cErr

        U_FLOGJG('O seguinte erro ocorreu: ' + __cErr+__cStack)

    END SEQUENCE

    ErrorBlock(bBlock)

    FWRestArea(aAreaSC5)
    FWRestArea(aAreaSC6)
    FWRestArea(aAreaSC9)

    FWFreeArray(aAreaSC5)
    FWFreeArray(aAreaSC6)
    FWFreeArray(aAreaSC9)

Return cStatus

/*/{Protheus.doc} fItensPed
description
    Verifica a quantidade de itens existentes no pedido.
@type function
@version  
@author Samsung
@since 09/03/2026
@param cFilial, character, param_description
@param cNumPed, character, param_description
@return variant, return_description
/*/
Static Function fItensPed(cFilPed, cNumPed)
    Local cQuery As String
    Local nCount As Numeric

	nCount := 0
    cQuery := ""

    cQuery += " SELECT " + CRLF
    cQuery += "     COUNT(*) AS NCOUNT " + CRLF
    cQuery += " FROM " + CRLF
    cQuery += "     "+RetSqlName("SC6")+" SC6 " + CRLF
    cQuery += " WHERE " + CRLF
    cQuery += "     "+RetSqlDel("SC6") + CRLF
	cQuery += "		AND C6_FILIAL = "+ValToSql(cFilPed) + CRLF
    cQuery += "     AND C6_NUM = "+ValToSql(cNumPed) + CRLF

    nCount := MpSysExecScalar(cQuery, "NCOUNT")

Return nCount

/*/{Protheus.doc} fSemOrdSep
description
    Verifica a quantidade de itens do pedido que nуo possuem ordem de separaчуo gerada.
@type function
@version  
@author Samsung
@since 09/03/2026
@param cFilial, character, param_description
@param cNumPed, character, param_description
@return variant, return_description
/*/
Static Function fSemOrdSep(cFilPed, cNumPed)

    Local cQuery As String
    Local nCount As Numeric

    // Legendas da CB7 - Ordens de Separaчуo - ACDA100:
    // aCores := {	{ "CB7->CB7_DIVERG == '1'", "DISABLE"  },;
    //             { "CB7->CB7_STATPA == '1'", "BR_CINZA" },;
    //             { "CB7->CB7_STATUS == '9'", "ENABLE"   },;
    //             { "CB7->CB7_STATUS $ '12345678'","BR_AMARELO" },;
    //             { "CB7->CB7_STATUS == '0'", "BR_AZUL"  } }

	nCount := 0
    cQuery := ""

    cQuery += " SELECT " + CRLF
    cQuery += "     COUNT(*) AS NCOUNT " + CRLF
    cQuery += " FROM " + CRLF
    cQuery += "     "+RetSqlName("SC6")+" SC6 " + CRLF
    cQuery += " WHERE " + CRLF
    cQuery += "     SC6.D_E_L_E_T_ <> '*' AND C6_FILIAL = "+ValToSql(cFilPed)+" AND C6_NUM = "+ValToSql(cNumPed)+" " + CRLF
    cQuery += "     AND NOT EXISTS(" + CRLF
    cQuery += "         SELECT " + CRLF
    cQuery += "             1 " + CRLF
    cQuery += "         FROM " + CRLF
    cQuery += "             "+RetSqlName("CB8")+" CB8 " + CRLF
    cQuery += "             INNER JOIN "+RetSqlName("CB7")+" CB7 ON CB7.D_E_L_E_T_ <> '*' " + CRLF
    cQuery += "                 AND CB7.CB7_FILIAL = CB8.CB8_FILIAL AND CB7_ORDSEP = CB8_ORDSEP AND CB7.CB7_PEDIDO = CB8.CB8_PEDIDO " + CRLF
    cQuery += "         WHERE " + CRLF
    cQuery += "             CB8.D_E_L_E_T_ <> '*' " + CRLF
    cQuery += "             AND CB8.CB8_FILIAL = SC6.C6_FILIAL AND CB8.CB8_PEDIDO = SC6.C6_NUM AND CB8.CB8_ITEM = SC6.C6_ITEM " + CRLF
    cQuery += "     ) " + CRLF

    nCount := MpSysExecScalar(cQuery, "NCOUNT")

Return nCount

/*/{Protheus.doc} fOrdNaoFin
description
    Verifica a quantidade de itens do pedido que possuem ordem de separaчуo gerada mas nуo finalizada.
@type function
@version  
@author Samsung
@since 09/03/2026
@param cFilial, character, param_description
@param cNumPed, character, param_description
@return variant, return_description
/*/
Static Function fOrdNaoFin(cFilPed, cNumPed)
    Local cQuery As String
    Local nCount As Numeric

	nCount := 0
    cQuery := ""

	cQuery += "	SELECT " + CRLF
	cQuery += "		SUM( CASE WHEN CB7_STATUS = '9' THEN 0 ELSE 1 END ) NCOUNT " + CRLF
	cQuery += "	FROM " + CRLF
	cQuery += "		( " + CRLF
	cQuery += "			SELECT " + CRLF
	cQuery += "				C6_FILIAL, C6_NUM, C6_ITEM, MAX(CB7.R_E_C_N_O_) RECNO_CB7 " + CRLF
	cQuery += "			FROM " + CRLF
	cQuery += "				SC6010 SC6 " + CRLF
	cQuery += "			INNER JOIN CB8010 CB8 ON " + CRLF
	cQuery += "				"+RetSqlDel("CB8") + CRLF
	cQuery += "				AND CB8_FILIAL = C6_FILIAL " + CRLF
	cQuery += "				AND CB8_PEDIDO = C6_NUM " + CRLF
	cQuery += "				AND CB8_ITEM   = C6_ITEM " + CRLF
	cQuery += "			INNER JOIN CB7010 CB7 ON " + CRLF
	cQuery += "				"+RetSqlDel("CB7") + CRLF
	cQuery += "				AND CB7_FILIAL = CB8_FILIAL " + CRLF
	cQuery += "				AND CB7_ORDSEP = CB8_ORDSEP " + CRLF
	cQuery += "				AND CB7_PEDIDO = CB8_PEDIDO " + CRLF
	cQuery += "			WHERE " + CRLF
    cQuery += "				"+RetSqlDel("SC6") + CRLF
    cQuery += "				AND C6_FILIAL = "+ValToSql(cFilPed) + CRLF
    cQuery += "				AND C6_NUM    = "+ValToSql(cNumPed) + CRLF
	cQuery += "			GROUP BY " + CRLF
	cQuery += "				C6_FILIAL, C6_NUM, C6_ITEM " + CRLF
	cQuery += "		) OS " + CRLF
	cQuery += "		INNER JOIN CB7010 CB7 ON CB7.R_E_C_N_O_ = OS.RECNO_CB7 " + CRLF

    // cQuery += " SELECT " + CRLF
    // cQuery += "     SUM( " + CRLF
    // cQuery += "         COALESCE( " + CRLF
    // cQuery += "             SELECT TOP 1 " + CRLF
    // cQuery += "                 CASE WHEN CB7_STATUS = '9' THEN 0 ELSE 1 END " + CRLF
    // cQuery += "             FROM " + CRLF
    // cQuery += "                 "+RetSqlName("CB8")+" CB8 " + CRLF
    // cQuery += "                 INNER JOIN "+RetSqlName("CB7")+" CB7 ON " + CRLF
    // cQuery += "                 	"+RetSqlDel("CB7") + CRLF
    // cQuery += "                     AND CB7_FILIAL = CB8_FILIAL " + CRLF
    // cQuery += "                 	AND ORDSEP     = ORDSEP " + CRLF
    // cQuery += "                 	AND CB7_PEDIDO = CB8_PEDIDO " + CRLF
    // cQuery += "                 	AND CB7_STATUS = '9' " + CRLF
    // cQuery += "             WHERE " + CRLF
    // cQuery += "                 "+RetSqlDel("CB8") + CRLF
    // cQuery += "                 AND CB8_FILIAL = SC6.C6_FILIAL " + CRLF
    // cQuery += "                 AND CB8_PEDIDO = SC6.C6_NUM " + CRLF
    // cQuery += "                 AND CB8_ITEM = SC6.C6_ITEM " + CRLF
    // cQuery += "             ORDER BY " + CRLF
    // cQuery += "                 CB7.R_E_C_N_O_ DESC " + CRLF
    // cQuery += "         , 0) " + CRLF
    // cQuery += "         ) NCOUNT " + CRLF
    // cQuery += " FROM " + CRLF
    // cQuery += "     "+RetSqlName("SC6")+" SC6 " + CRLF
    // cQuery += " WHERE " + CRLF
    // cQuery += "     "+RetSqlDel("SC6") + CRLF
    // cQuery += "     AND C6_FILIAL = "+ValToSql(cFilPed) + CRLF
    // cQuery += "     AND C6_NUM = "+ValToSql(cNumPed) + CRLF
    // cQuery += "     AND NOT EXISTS(" + CRLF
    // cQuery += "         SELECT DISTINCT " + CRLF
    // cQuery += "             1 " + CRLF
    // cQuery += "         FROM " + CRLF
    // cQuery += "             "+RetSqlName("CB8")+" CB8 " + CRLF
    // cQuery += "             INNER JOIN "+RetSqlName("CB7")+" CB7 ON " + CRLF
    // cQuery += "             	"+RetSqlDel("CB7") + CRLF
    // cQuery += "                 AND CB7.CB7_FILIAL = CB8.CB8_FILIAL " + CRLF
    // cQuery += "             	AND CB7_ORDSEP = CB8_ORDSEP " + CRLF
    // cQuery += "             	AND CB7.CB7_PEDIDO = CB8.CB8_PEDIDO " + CRLF
    // cQuery += "             	AND CB7.CB7_STATUS = '9' " + CRLF
    // cQuery += "         WHERE " + CRLF
    // cQuery += "             "+RetSqlDel("CB8") + CRLF
    // cQuery += "             AND CB8.CB8_FILIAL = SC6.C6_FILIAL " + CRLF
    // cQuery += "             AND CB8.CB8_PEDIDO = SC6.C6_NUM " + CRLF
    // cQuery += "             AND CB8.CB8_ITEM = SC6.C6_ITEM " + CRLF
    // cQuery += "     ) " + CRLF

    nCount := MpSysExecScalar(cQuery, "NCOUNT")

Return nCount

/*/{Protheus.doc} fLoteComErro

	Verifica a quantidade de itens do pedido que possuem algum problema relacionado ao lote, como por exemplo:
	- produto com controle de lote, mas sem lote informado;
	- produtos com controle de lote, com lote informado, mas o lote nуo existe na SB8.

@type function
@version  
@author Samsung
@since 09/03/2026
@param cFilial, character, param_description
@param cNumPed, character, param_description
@return variant, return_description
/*/
Static Function fLoteComErro(cFilPed, cNumPed)
    Local cQuery As String
    Local nCount As Numeric

	nCount := 0
    cQuery := ""

    cQuery += " SELECT " + CRLF
	cQuery += "		COUNT(*) NCOUNT " + CRLF
	cQuery += "	FROM " + CRLF
	cQuery += "		"+RetSqlName("SC6")+" SC6 " + CRLF
	cQuery += "		LEFT JOIN "+RetSqlName("SB1")+" SB1 ON "+RetSqlDel("SB1")+" AND B1_FILIAL = "+ValToSql(FWxFilial("SB1"))+" AND B1_COD = C6_PRODUTO " + CRLF
	cQuery += "	WHERE " + CRLF
	cQuery += "		"+RetSqlDel("SC6")+" AND C6_FILIAL = "+ValToSql(cFilPed)+" AND C6_NUM = "+ValToSql(cNumPed)+" " + CRLF
	cQuery += "		AND	(COALESCE(B1_COD, ' ') = ' ' " + CRLF
	cQuery += "				OR	B1_RASTRO = 'L' AND C6_LOTECTL = ' ' " + CRLF
	cQuery += "				OR	B1_RASTRO = 'L' " + CRLF
	cQuery += "					AND NOT EXISTS( " + CRLF
	cQuery += "						SELECT " + CRLF
	cQuery += "							DISTINCT 1 " + CRLF
	cQuery += "						FROM " + CRLF
	cQuery += "							" + RetSqlName("SB8")+" SB8 " + CRLF
	cQuery += "						WHERE " + CRLF
	cQuery += "							" + RetSqlDel("SB8") + CRLF
	cQuery += "							AND B8_FILIAL  = C6_FILIAL " + CRLF
	cQuery += "							AND B8_PRODUTO = C6_PRODUTO " + CRLF
	cQuery += "							AND B8_LOCAL   = C6_LOCAL " + CRLF
	cQuery += "							AND B8_LOTECTL = C6_LOTECTL " + CRLF
	cQuery += "							AND B8_NUMLOTE = C6_NUMLOTE " + CRLF
	cQuery += "							AND B8_DTVALID = C6_DTVALID " + CRLF
	cQuery += "						) " + CRLF
	cQuery += "			) " + CRLF

    nCount := MpSysExecScalar(cQuery, "NCOUNT")

Return nCount
