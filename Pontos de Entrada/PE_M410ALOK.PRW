#INCLUDE "TOTVS.CH"

/*/{Protheus.doc} M410ALOK
Ponto de Entrada executado antes de iniciar a alteraçăo, exclusăo ou cópia de um Pedido de Venda.
@type function
@version Protheus 12
@author  Jesus Ramos
@since   12/02/2026
/*/
User Function M410ALOK

	Local aAreaSC5    := SC5->(GetArea())
	Local aArea       := GetArea()
	Local lRetorno    := .T.

	If !Empty(SC5->C5_NOTA)
		If ALTERA //Alteraçăo
			FwAlertError("O pedido já está faturado.","ATENÇĂO - Alteraçăo")
			lRetorno := .F.
		ElseIf !INCLUI .And. !ALTERA //Exclusăo
			FwAlertError("O pedido já está faturado.","ATENÇĂO - Exclusăo")
			lRetorno := .F.

		// ElseIf INCLUI .And. FWIsInCallStack("A410COPIA") //Cópia
		// 	If FwIsAdmin()
		// 		lRetorno := .T.
		// 	Else
		// 		FwAlertError("O pedido já está faturado.","ATENÇĂO - Cópia")
		// 	EndIf

		EndIf

	EndIf

	RestArea(aAreaSC5)
	RestArea(aArea)

	If lRetorno
		If Type("__bkKCtrlL") == "U"
			Public __bkKCtrlL
		EndIf
		__bkKCtrlL := SetKey( K_CTRL_L ) //Guarda a configuraçăo atual da tecla CTRL+L
		SetKey( K_CTRL_L, {|| U_JGRT007()} ) //Atalho para seleçăo do lote/sublote/validade
	EndIf

Return(lRetorno)
